# OAuth token from https://account.bitquery.io
BITQUERY_TOKEN=ory_at_your_token_here

# Regional endpoint (default: Europe)
BITQUERY_GRAPHQL_URL=https://streaming.bitquery.io/graphql

# Receiver pool (required)
RECEIVERS_POOL_PATH=data/receivers_pool.json
DISCOVER_TOP_N=2000
DISCOVER_LIGHT_N=2000
# RANDOM_SEED=42

# Nomics SLA max records per query
QUERY_LIMIT=20000

# Optional: where logs/sla_<timestamp>.log files are written
LOG_DIR=logs

# SLA defaults (override on CLI: --qps, --response-time, --freshness)
SLA_PEAK_QPS=4
SLA_RESPONSE_SEC=5
SLA_FRESHNESS_SEC=60

# Freshness WebSocket listen time (600 = 10 minutes)
FRESHNESS_SUBSCRIPTION_SEC=600
