# OAuth token from https://account.bitquery.io
BITQUERY_TOKEN=ory_at_your_token_here

# Regional endpoint (default: Europe)
BITQUERY_GRAPHQL_URL=https://streaming.bitquery.io/graphql

# Receiver pool (required)
RECEIVERS_POOL_PATH=data/receivers_pool.json
DISCOVER_TOP_N=2000
DISCOVER_LIGHT_N=2000
# RANDOM_SEED=42

# Nomics SLA max records per query
QUERY_LIMIT=20000

# Optional: where logs/sla_<timestamp>.log files are written
LOG_DIR=logs

# SLA defaults (override on CLI: --qps, --response-time, --freshness)
SLA_PEAK_QPS=4
SLA_RESPONSE_SEC=5
SLA_FRESHNESS_SEC=60

# Freshness WebSocket listen time (600 = 10 minutes)
FRESHNESS_SUBSCRIPTION_SEC=600

# ---------- W3C multi-chain SLA (separate scenario) ----------
# Bitquery V1 endpoint — REQUIRED for Solana (V2 Solana is only ~last 8h of data).
# EVM chains use BITQUERY_GRAPHQL_URL (V2 EAP) above.
BITQUERY_V1_URL=https://graphql.bitquery.io

# Defaults (CLI flags override): --qps, --concurrency, --duration, --response-time
W3C_TARGET_QPS=72
W3C_CONCURRENCY=42
W3C_DURATION_SEC=60
W3C_RESPONSE_SEC=10
W3C_ERROR_RATE_PCT=1.0

# Address pool + workload knobs
W3C_ADDRESSES_PATH=data/w3c_addresses.json
W3C_MIN_ADDRESSES=1
W3C_MAX_ADDRESSES=3
W3C_DATE_WINDOW_DAYS=365
# W3C_LOG_EVERY_N=1
# W3C_PROGRESS_EVERY_N=200

# Discovery defaults (top-receivers per chain over the last D days)
W3C_DISCOVER_PER_CHAIN=1000
W3C_DISCOVER_DAYS=365
# Optional: shorter discovery window just for Solana (V1 aggregation is heavier
# per day than V2 EVM). Leave unset to use W3C_DISCOVER_DAYS for all chains.
# W3C_DISCOVER_SOLANA_DAYS=30
W3C_DISCOVER_TIMEOUT_SEC=300
# Realism cap: drop DEX routers / CEX hot wallets with too many transfers (the
# raw "top by descending tx count" includes addresses with 15M+ txs that always
# blow the SLA — not representative of W3C end-users).
#   * EVM    → desc + `count(selectWhere: {ge:$min, lt:$max})` server-side
#   * Solana → asc + client-side filter (already low-count by construction)
W3C_DISCOVER_MAX_TXS=50000
W3C_DISCOVER_MIN_TXS=0
# Over-fetch multiplier for chains that filter client-side (Solana). Default 1
# because asc-ordering already keeps Solana under the cap.
W3C_DISCOVER_OVERFETCH=1
